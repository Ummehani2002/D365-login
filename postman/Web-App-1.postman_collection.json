{
	"info": {
		"_postman_id": "d265-web-app-1",
		"name": "WEB APP 1",
		"description": "API calls for this Laravel app. Set collection variables: base_url, api_bearer_token (same as WEBAPP_API_BEARER_TOKEN on the server). Companies come first — create companies before projects that reference company_id.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		},
		{
			"key": "api_bearer_token",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{api_bearer_token}}",
				"type": "string"
			}
		]
	},
